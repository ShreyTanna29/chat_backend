// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String               @id @default(cuid())
  email                String               @unique
  password             String?
  googleId             String?              @unique
  appleId              String?              @unique
  name                 String
  avatar               String?
  isVerified           Boolean              @default(false)
  refreshToken         String?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  pushToken            String? // Expo push notification token
  searchHistory        Json[]               @default([])
  preferences          Json                 @default("{\"theme\":\"auto\",\"language\":\"en\"}")
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  conversations        Conversation[]
  spaces               Space[] // Spaces owned by user
  spaceMemberships     SpaceMember[] // Spaces where user is a member
  sharedConversations  SharedConversation[]
  reminders            Reminder[]
  sessions             Session[]
  codeProjects         CodeProject[]

  @@map("users")
}

model Conversation {
  id                  String               @id @default(cuid())
  userId              String
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  title               String               @default("New Chat")
  messages            Message[]
  sharedConversations SharedConversation[]
  spaceId             String?
  space               Space?               @relation(fields: [spaceId], references: [id], onDelete: SetNull)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([userId])
  @@index([spaceId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // "user" or "assistant"
  content        String       @db.Text
  metadata       Json?        @default("{}") // For storing model, tokens, images, etc.
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@map("messages")
}

/// New: A Space groups conversations and provides an optional default system prompt
model Space {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  defaultPrompt String?        @db.Text
  conversations Conversation[]
  members       SpaceMember[] // Users who are members of this space
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([userId, name])
  @@index([userId])
  @@map("spaces")
}

/// SpaceMember: Junction table for many-to-many relationship between Users and Spaces
model SpaceMember {
  id      String   @id @default(cuid())
  spaceId String
  space   Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role    String   @default("member") // "owner", "admin", or "member"
  addedAt DateTime @default(now())
  addedBy String? // UserId of who added this member

  @@unique([spaceId, userId]) // A user can only be added once to a space
  @@index([spaceId])
  @@index([userId])
  @@map("space_members")
}

/// SharedConversation: Stores share links for public conversation access
model SharedConversation {
  id             String       @id @default(cuid())
  shareId        String       @unique @db.VarChar(32)
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sharedBy       String
  user           User         @relation(fields: [sharedBy], references: [id])
  sharedAt       DateTime     @default(now())

  @@index([shareId])
  @@index([conversationId])
  @@map("shared_conversations")
}

/// Reminder: Stores scheduled reminders for users
model Reminder {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String // User-friendly title like "Daily Stock Updates"
  prompt    String    @db.Text // The original prompt like "give updates on the stock market daily at 5PM"
  aiPrompt  String    @db.Text // The actual prompt to send to AI
  schedule  String // Cron expression (e.g., "0 17 * * *" for daily at 5PM)
  timezone  String    @default("UTC") // User's timezone
  isActive  Boolean   @default(true)
  lastRun   DateTime?
  nextRun   DateTime?
  metadata  Json?     @default("{}") // Additional data like conversation settings
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([isActive])
  @@index([nextRun])
  @@map("reminders")
}

/// Session: Stores active authentication sessions for multi-device support
model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique
  deviceInfo   String? // E.g., "iPhone 14 Pro", "Chrome on Windows", etc.
  ipAddress    String?
  lastActive   DateTime @default(now())
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([refreshToken])
  @@index([expiresAt])
  @@map("sessions")
}

/// CodeProject: Stores published projects from the Code Builder feature
model CodeProject {
  id          String   @id @default(cuid())
  slug        String   @unique // URL-safe name, e.g. "my-app-k7x2f"
  name        String // Human-readable project name
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  files       Json // Array of { path, content, type }
  distFiles   Json? // Built static files: { "index.html": { content, binary } ... }
  buildStatus String   @default("pending") // "pending" | "building" | "ready" | "failed"
  buildError  String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("code_projects")
}
